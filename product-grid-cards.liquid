{{ 'product-grid-cards.css' | asset_url | stylesheet_tag }}

<style>
  #pgc-{{ section.id }} {
    --pgc-columns: {{ section.settings.columns_desktop }};
    --pgc-columns-mobile: {{ section.settings.columns_mobile }};
    --pgc-bg: {{ section.settings.bg_color }};
    --pgc-card-bg: {{ section.settings.card_bg_color }};
    --pgc-card-info-bg: {{ section.settings.card_info_bg_color }};
    --pgc-heading-color: {{ section.settings.heading_color }};
    --pgc-category-color: {{ section.settings.category_color }};
    --pgc-title-color: {{ section.settings.title_color }};
    --pgc-price-color: {{ section.settings.price_color }};
    --pgc-compare-price-color: {{ section.settings.compare_price_color }};
    --pgc-star-color: {{ section.settings.star_color }};
    --pgc-rating-number-color: {{ section.settings.rating_number_color }};
    --pgc-rating-count-color: {{ section.settings.rating_count_color }};
    --pgc-btn-text-color: {{ section.settings.button_text_color }};
    --pgc-btn-border-color: {{ section.settings.button_border_color }};
    --pgc-btn-bg-color: {{ section.settings.button_bg_color }};
    --pgc-card-radius: {{ section.settings.card_radius }}px;
    --pgc-button-radius: {{ section.settings.button_radius }}px;
    --pgc-gap: {{ section.settings.card_gap }}px;
    --pgc-padding-top: {{ section.settings.padding_top }}px;
    --pgc-padding-bottom: {{ section.settings.padding_bottom }}px;
    --pgc-heading-size: {{ section.settings.heading_size }}px;
    --pgc-heading-align: {{ section.settings.heading_alignment }};
    --pgc-heading-weight: {{ section.settings.heading_weight }};
    --pgc-badge-bg: {{ section.settings.badge_bg_color }};
    --pgc-badge-text: {{ section.settings.badge_text_color }};
    --pgc-category-size: {{ section.settings.category_size }}px;
    --pgc-title-size: {{ section.settings.title_size }}px;
    --pgc-rating-size: {{ section.settings.rating_size }}px;
    --pgc-price-size: {{ section.settings.price_size }}px;
    --pgc-compare-price-size: {{ section.settings.compare_price_size }}px;
    --pgc-button-text-size: {{ section.settings.button_text_size }}px;
    --pgc-title-weight: {{ section.settings.title_weight }};
    --pgc-price-weight: {{ section.settings.price_weight }};
    --pgc-button-weight: {{ section.settings.button_weight }};
    {%- if section.settings.image_aspect_ratio == 'auto' -%}
      --pgc-image-height: {{ section.settings.image_height }}px;
      --pgc-image-aspect: auto;
    {%- else -%}
      --pgc-image-height: auto;
      --pgc-image-aspect: {{ section.settings.image_aspect_ratio }};
    {%- endif -%}
  }
</style>

<div class="pgc-section" id="pgc-{{ section.id }}">
  <div class="pgc-container">

    {%- if section.settings.heading != blank -%}
      <h2 class="pgc-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="pgc-grid">
      {%- for block in section.blocks -%}
        {%- assign product = block.settings.product -%}

        <div class="pgc-card" {{ block.shopify_attributes }}>

          {%- if product != blank -%}
            <a href="{{ product.url }}" class="pgc-card-link" aria-label="{{ product.title | escape }}"></a>
          {%- endif -%}

          <div class="pgc-image-wrap">
            {%- if section.settings.show_discount_badge and product != blank and product.compare_at_price > product.price -%}
              {%- assign discount_percent = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
              <span class="pgc-discount-badge">{{ discount_percent }}% OFF</span>
            {%- elsif section.settings.show_discount_badge and product == blank and block.settings.compare_price_fallback != blank and block.settings.price_fallback != blank -%}
              <span class="pgc-discount-badge">{{ block.settings.discount_badge_fallback | default: 'SALE' }}</span>
            {%- endif -%}

            {%- if product != blank and product.featured_image != blank -%}
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.featured_image.alt | escape }}"
                class="pgc-image"
                loading="lazy"
                width="600"
                height="{{ 600 | divided_by: product.featured_image.aspect_ratio }}"
              >
            {%- else -%}
              <div class="pgc-icon-placeholder">
                {%- case block.settings.placeholder_icon -%}
                  {%- when 'shoe' -%}
                    {%- render 'pgc-icon-shoe' -%}
                  {%- when 'bag' -%}
                    {%- render 'pgc-icon-bag' -%}
                  {%- when 'shirt' -%}
                    {%- render 'pgc-icon-shirt' -%}
                  {%- else -%}
                    {%- render 'pgc-icon-shoe' -%}
                {%- endcase -%}
              </div>
            {%- endif -%}
          </div>

          <div class="pgc-info">
            <p class="pgc-category">
              {%- if product != blank -%}
                {{ product.type | default: block.settings.category_fallback }}
              {%- else -%}
                {{ block.settings.category_fallback }}
              {%- endif -%}
            </p>

            <h3 class="pgc-title">
              {%- if product != blank -%}
                {{ product.title }}
              {%- else -%}
                {{ block.settings.title_fallback }}
              {%- endif -%}
            </h3>

            <!-- Rating: connect this to your review app (Judge.me / Loox / Shopify Reviews) -->
            <div class="pgc-rating">
              {%- assign rating_value = block.settings.manual_rating -%}
              {%- assign full_stars = rating_value | floor -%}
              {%- assign has_half = false -%}

              {%- for i in (1..5) -%}
                {%- if i <= full_stars -%}
                  <span class="pgc-star pgc-star-full">★</span>
                {%- else -%}
                  <span class="pgc-star pgc-star-empty">☆</span>
                {%- endif -%}
              {%- endfor -%}

              <span class="pgc-rating-number">{{ rating_value }}</span>
              <span class="pgc-rating-count">({{ block.settings.review_count }})</span>
            </div>

            <div class="pgc-price-row">
              {%- if product != blank -%}
                <span class="pgc-price">{{ product.price | money }}</span>
                {%- if product.compare_at_price > product.price -%}
                  <span class="pgc-compare-price">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
              {%- else -%}
                <span class="pgc-price">{{ block.settings.price_fallback }}</span>
                {%- if block.settings.compare_price_fallback != blank -%}
                  <span class="pgc-compare-price">{{ block.settings.compare_price_fallback }}</span>
                {%- endif -%}
              {%- endif -%}
            </div>

            <button
              type="button"
              class="pgc-add-btn"
              {%- if product != blank -%}
                onclick="event.stopPropagation(); pgcAddToCart('{{ product.selected_or_first_available_variant.id }}', this)"
              {%- endif -%}
            >
              {{ block.settings.button_text | default: 'Add to cart' }}
            </button>
          </div>

        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

<script>
  function pgcAddToCart(variantId, btn) {
    if (!variantId) return;
    btn.disabled = true;
    const originalText = btn.textContent;
    btn.textContent = 'Adding...';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(res => res.json())
    .then(() => {
      btn.textContent = 'Added ✓';
      setTimeout(() => {
        btn.textContent = originalText;
        btn.disabled = false;
      }, 1500);
    })
    .catch(() => {
      btn.textContent = 'Error';
      setTimeout(() => {
        btn.textContent = originalText;
        btn.disabled = false;
      }, 1500);
    });
  }
</script>

